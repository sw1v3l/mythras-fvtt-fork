<div class="encumbrance-bar">
  <div class="encumbrance-bar-names">
    {{#each encumbrance.barSegments as |segment id|}}
    <div style="flex: {{ segment.width }};{{#if @first}}justify-content: space-between;{{/if}}" class="bar-label">
      {{#if @first}}<p>{{localize 'MYTHRAS.Current_ENC'}}: {{roundNumber ../encumbrance.currentEncumbrance 2}}</p> {{/if}}
      <p>{{localize (concat 'MYTHRAS.' segment.levelName)}}</p>
    </div>
    {{/each}}
  </div>
  <div class="encumbrance-bar-display">
    {{#each encumbrance.barSegments as |segment id|}}
    <div style="flex: {{ segment.width }}" class="bar-segment">
      <div class="percent-segment-filled" style="width: {{ segment.percentFilled }}%;"></div>
    </div>
    {{/each}}
  </div>
  <div class="encumbrance-bar-values">
    {{#each encumbrance.barSegments as |segment id|}}
    <div style="flex: {{ segment.width }}" class="bar-label">
      <p>{{ segment.level }}</p>
    </div>
    {{/each}}
  </div>
</div>
